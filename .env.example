# Public site URL (no trailing slash). Used for metadata, sitemap, and JSON-LD.
# Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Calendly — used for “Book a call” / primary scheduling (opens in a new tab).
# Example: https://calendly.com/your-handle/30-minute-meeting
NEXT_PUBLIC_CALENDLY_URL=

# Contact email — used for the “Start a project” mailto in CTA (required for that button).
# NEXT_PUBLIC_CONTACT_EMAIL=you@example.com

# Profile / schema.org — public name and location (Senegal + international positioning).
# NEXT_PUBLIC_PROFILE_NAME=Your Name
# NEXT_PUBLIC_PROFILE_CITY=Dakar
# NEXT_PUBLIC_PROFILE_COUNTRY=Senegal
# NEXT_PUBLIC_PROFILE_COUNTRY_CODE=SN

# Resume / CV — recruiters. Either host a PDF in `public/resume.pdf` OR set an external URL.
# NEXT_PUBLIC_RESUME_URL=https://example.com/your-cv.pdf

# Optional — full profile URLs for footer links and Person schema `sameAs`.
# NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/yourprofile
# NEXT_PUBLIC_GITHUB_URL=https://github.com/yourusername
